{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs npm exec prettier -- --write"
          }
        ]
      }
    ]
  },
  "permissions": {
    "additionalDirectories": [
      "/Users/dmull/personal/motortown-decal-tool/src"
    ],
    "allow": [
      "Bash(npm run build)"
    ]
  }
}