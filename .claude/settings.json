{
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npx tsc --noEmit)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs npm exec prettier -- --write"
          }
        ]
      }
    ]
  }
}
